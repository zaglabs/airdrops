# RPC URL (tests and Anchor)
ANCHOR_PROVIDER_URL=http://127.0.0.1:8899

# Wallet that signs deploy/migrate (path to keypair JSON)
ANCHOR_WALLET=/path/to/your/wallet.json

# Fee instance 1
FEE_RECIPIENT_1=<base58-pubkey>
AUTHORITY_SEED_1=<64-hex-chars>
FEE_AMOUNT_1=100000000

# Fee instance 2
FEE_RECIPIENT_2=<base58-pubkey>
AUTHORITY_SEED_2=<64-hex-chars>
FEE_AMOUNT_2=100000000

# Optional: override admin for instances (defaults to fee recipient)
# AUTHORITY_1=<base58-pubkey>
# AUTHORITY_2=<base58-pubkey>

# Optional: program ID when not using default
# AIRDROP_PROGRAM_ID=<base58-pubkey>
